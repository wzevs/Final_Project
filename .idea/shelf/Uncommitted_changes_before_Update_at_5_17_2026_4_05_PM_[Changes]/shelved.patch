<+>from dataclasses import dataclass\r\n\r\n\r\n@dataclass\r\nclass Product:\r\n    brand: str\r\n    name: str\r\n    quantity: int\r\n    price: float\r\n    rrp_price: float\r\n    category: str  # აქ შეინახება ქვეკატეგორია ან იდენტიფიცირებული ტიპი\r\n\r\n    def validate(self):\r\n        # სახელის ვალიდაცია\r\n        if not self.name or str(self.name).lower() == \"nan\":\r\n            raise ValueError(\"პროდუქტის სახელი ცარიელია ან არასწორია\")\r\n\r\n        # ბრენდის გასუფთავება\r\n        if not self.brand or str(self.brand).lower() == \"nan\":\r\n            self.brand = \"Unknown\"\r\n\r\n        # ფასის ვალიდაცია\r\n        if self.price < 0:\r\n            raise ValueError(f\"უარყოფითი ფასი: {self.name}\")\r\n\r\n        # რაოდენობის ვალიდაცია (რომ შემთხვევით უარყოფითი არ ჩავწეროთ)\r\n        if self.quantity < 0:\r\n            self.quantity = 0
