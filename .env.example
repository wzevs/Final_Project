# GITEC API
GITEC_USERNAME=your_username
GITEC_PASSWORD=your_password

# Alta B2B SOAP — http://extra.alta.com.ge/b2b/b2bEWS
ALTA_USERNAME=your_alta_username
ALTA_PASSWORD=your_alta_password
# ALTA_SOAP_URL=http://extra.alta.com.ge/b2b/b2bEWS

# VRTX B2B — https://vrtx.ge
VRTX_USERNAME=your_vrtx_email
VRTX_PASSWORD=your_vrtx_password
VRTX_API_TOKEN=your_vrtx_api_token
# VRTX_API_URL=https://vrtx.ge/index.php?route=api/app/items&token=...

# ავტორიზაცია (მინიმუმ 32 სიმბოლოანი შემთხვევითი გასაღები)
AUTH_COOKIE_KEY=change_me_to_a_long_random_secret_key_32chars

# რეგისტრაციის ჩართვა (ნაგულისხმევი: გამორთული)
ALLOW_REGISTRATION=false

# Dev რეჟიმი main.py-სთვის — ავტორიზაციის გარეშე (მხოლოდ ლოკალურად!)
ALLOW_DEV_NO_AUTH=false
